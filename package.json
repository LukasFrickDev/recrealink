{
  "name": "recrealink-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:recreador:t1": "vitest run tests/recreador/t1",
    "test:recreador:t2": "vitest run tests/recreador/t2",
    "test:recreador:t3": "vitest run tests/recreador/t3",
    "test:recreador:t4": "playwright test --config=playwright.config.ts tests/recreador/t4",
    "test:recreador:t5": "vitest run tests/recreador/t5",
    "test:recreador:additional": "vitest run tests/recreador/additional",
    "test:recreador:all": "npm run test:recreador:t1 && npm run test:recreador:t2 && npm run test:recreador:t3 && npm run test:recreador:t4 && npm run test:recreador:t5 && npm run test:recreador:additional"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "styled-components": "^6.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
